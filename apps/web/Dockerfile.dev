# Frontend dev mode: Vite + React + pnpm with hot reload.
FROM node:22-alpine

ENV PNPM_HOME="/pnpm" \
    PATH="/pnpm:$PATH"

RUN corepack enable

WORKDIR /app

# Cache deps layer
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Source is bind-mounted at runtime; copy as a fallback for first build.
COPY . .

EXPOSE 5173

CMD ["pnpm", "dev", "--host", "0.0.0.0"]
