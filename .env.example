# Local dev — copy to .env (gitignored) and fill in secrets

# Backend port (avoid 8000 — commonly taken by other services)
PORT=8001

# Database (Homebrew Postgres uses OS user as default, no password)
DATABASE_URL=postgresql+asyncpg://anishsuman@localhost:5432/mrmarket
SYNC_DATABASE_URL=postgresql://anishsuman@localhost:5432/mrmarket

# Redis
REDIS_URL=redis://localhost:6379/0

# Active LLM provider — OpenAI Codex OAuth
# Codex OAuth/CLI uses GPT-5.4 mini. If Codex is not connected, the app can
# fall back to the existing backend OPENAI_API_KEY on GPT-4o mini.
OPENAI_API_KEY=
OPENAI_ALLOW_ENV_CREDENTIALS=true
OPENAI_REDIRECT_URI=http://localhost:1455/auth/callback
OPENAI_MODEL_WORK=gpt-5.4-mini
OPENAI_MODEL_ROUTER=gpt-5.4-mini
OPENAI_FALLBACK_MODEL_WORK=gpt-4o-mini
OPENAI_FALLBACK_MODEL_ROUTER=gpt-4o-mini

# Demo auth
JWT_SECRET=change-me-in-local-env
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# Mem0 personalization memory (OpenAI extraction/embeddings + Pinecone vector store)
MEM0_ENABLED=false
PINECONE_API_KEY=
PINECONE_INDEX_NAME=midas-memories
PINECONE_CLOUD=aws
PINECONE_REGION=us-west-2
PINECONE_NAMESPACE=midas
PINECONE_METRIC=cosine
MEM0_EMBEDDING_MODEL=text-embedding-3-small
MEM0_EMBEDDING_DIMS=1536
MEM0_MIN_SCORE=0.3
MEM0_MAX_INJECT=5
MEM0_HISTORY_DB_PATH=data/mem0-history.db

# Reserved (Phase 2 swap)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# RAG vector store. Default 'jsonb' (Postgres JSONB + numpy cosine).
# Set to 'pinecone' and paste the API key to use the cloud index instead.
VECTOR_BACKEND=jsonb
PINECONE_API_KEY=
PINECONE_INDEX_NAME=mr-market
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

LOG_LEVEL=INFO
ENV=local
